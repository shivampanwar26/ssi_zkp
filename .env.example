# RPC URLs (Get from Alchemy, Infura, or similar)
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_API_KEY
MAINNET_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_API_KEY

# Private Key for deployment (DO NOT COMMIT THIS!)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PRIVATE_KEY=your_private_key_here

# Etherscan API Key (for contract verification)
# Get from: https://etherscan.io/myapikey
ETHERSCAN_API_KEY=your_etherscan_api_key

# Wallet Password (for encrypting agent wallets)
WALLET_PASSWORD=your_secure_password_here

# Network Selection
# =================================
# Options: sepolia, localhost, mainnet
BLOCKCHAIN_NETWORK=sepolia

# Application Configuration
# =================================
# Enable/disable blockchain features
USE_BLOCKCHAIN=true

# Contract deployer / Funder specific keys (If different from PRIVATE_KEY)
FUNDER_PRIVATE_KEY=your_funder_private_key_here
DEPLOYER_PRIVATE_KEY=your_deployer_private_key_here
